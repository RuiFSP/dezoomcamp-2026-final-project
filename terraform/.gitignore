# .gitignore for Terraform
# Prevent accidental commits of sensitive data

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (sensitive!)
*.tfvars
*.tfvars.json

# Ignore override files (local customizations)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock files (optional, but recommended for team collaboration)
.terraform.lock.hcl

# Ignore macOS files
.DS_Store

# IDE files
.idea/
*.swp
*.swo
*~
