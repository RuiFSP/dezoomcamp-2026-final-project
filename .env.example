# Environment Variables Template
# Copy to .env and fill in your values (add .env to .gitignore!)

# GCP Configuration
GCP_PROJECT_ID=gh-dezoomcamp
GCS_BUCKET_NAME=gh-dezoomcamp-raw-events
BQ_DATASET_ID=gh_analytics
GCP_REGION=europe-west1

# GCP Credentials (path to service account JSON key)
GOOGLE_APPLICATION_CREDENTIALS=/home/your-user/gcp-key.json

# Pipeline Configuration
GITHUB_ARCHIVE_DATE=2026-03-20   # Date to ingest (YYYY-MM-DD), defaults to yesterday if not set

# Hour window (optional — for smoke testing / partial ingestion)
# GH_ARCHIVE_START_HOUR=0        # First UTC hour to ingest (0-23, default: 0)
# GH_ARCHIVE_MAX_HOURS=24        # Number of hours to ingest (default: 24 = full day)
